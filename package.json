{
  "name": "daten-dashboards-frontend",
  "version": "0.1.0",
  "description": "Angular frontend for the local Daten Dashboards lab-results assistant.",
  "author": "Benjamin Bennewitz",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4300",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "tree": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\make-tree.ps1 -Depth 10 -Files -OutFile .\\tree.txt"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "sass": "^1.93.0",
    "typescript": "~5.9.3"
  }
}
